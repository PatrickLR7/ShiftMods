# Shopify Storefront API — find this in your Shopify admin under
# Sales Channels > Headless > Storefront API access tokens
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=       # e.g. your-store.myshopify.com

# Public Storefront API token — this is safe to expose in the browser
SHOPIFY_STOREFRONT_ACCESS_TOKEN=        # Starts with shpat_ or a 32-char hex token

# Sanity project credentials — find these in manage.sanity.io
NEXT_PUBLIC_SANITY_PROJECT_ID=          # e.g. abc123xy
NEXT_PUBLIC_SANITY_DATASET=production   # usually "production"

# Server-side Sanity token — grants read/write access for draft previews and webhooks
# Create in manage.sanity.io > API > Tokens — set "Editor" role at minimum
SANITY_API_TOKEN=                       # Starts with sk

# Secret shared between Sanity webhook config and this app to verify webhook authenticity
# Generate with: openssl rand -base64 32
SANITY_WEBHOOK_SECRET=
